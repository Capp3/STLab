# ST Lab Environment Variables
# Copy this file to .env and fill in values for local development

# Server
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=stlab
DB_PASSWORD=stlab
DB_NAME=stlab

# Redis (optional — app degrades gracefully without it)
# REDIS_URL=redis://localhost:6379

# Session
SESSION_SECRET=change-me-to-a-secure-random-string

# Report output directory (inside container: /app/data/reports)
REPORTS_DIR=./data/reports
