{
  "name": "stlab",
  "version": "0.1.0",
  "description": "SMPTE ST 2110 engineering design and simulation platform",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Capp3/STLab"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "mocha --require tsx/esm 'tests/**/*.test.ts'",
    "lint": "eslint src tests eslint.config.mjs vite.config.ts drizzle.config.ts",
    "lint:fix": "eslint src tests eslint.config.mjs vite.config.ts drizzle.config.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "contributors": [
    {
      "name": "Cappy"
    }
  ],
  "dependencies": {
    "@xyflow/react": "^12.7.0",
    "ajv": "^8.18.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.43.1",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "ioredis": "^5.6.1",
    "js-yaml": "^4.1.1",
    "mustache": "^4.2.0",
    "pg": "^8.14.1",
    "puppeteer": "^24.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.1.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/express-session": "^1.18.1",
    "@types/js-yaml": "^4.0.9",
    "@types/mustache": "^4.2.5",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.14",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "@eslint/js": "^9.28.0",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "mocha": "^10.8.2",
    "prettier": "^3.5.3",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.3",
    "supertest": "^7.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=22"
  }
}
